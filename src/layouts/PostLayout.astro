---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  collection: 'blog' | 'research' | 'notes' | 'projects';
  readingTime?: string;
}

const { title, description, date, tags, collection, readingTime } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const collectionLabels: Record<string, string> = {
  blog:     'Blog',
  research: 'Research',
  notes:    'Notes',
  projects: 'Projects',
};
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <header class="post-header" data-collection={collection}>
      <a href={`/${collection}`} class="post-back">{collectionLabels[collection]}</a>

      <h1 class="post-title">{title}</h1>
      <p class="post-dek">{description}</p>

      <dl class="post-meta" aria-label="Post metadata">
        <div>
          <dt>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 2v4M16 2v4M3 10h18" />
              <rect x="3" y="4" width="18" height="18" rx="2" />
            </svg>
            Published
          </dt>
          <dd><time datetime={date.toISOString()}>{dateStr}</time></dd>
        </div>
        {readingTime && (
          <div>
            <dt>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" />
              </svg>
              Read time
            </dt>
            <dd>{readingTime}</dd>
          </div>
        )}
        {tags.length > 0 && (
          <div class="post-meta-topic">
            <dt>Topics</dt>
            <dd class="post-meta-tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </dd>
          </div>
        )}
      </dl>
    </header>

    <article class="prose" data-collection={collection}>
      <slot />
    </article>

    <div class="post-footer">
      <a href={`/${collection}`} class="post-back">← Back to {collectionLabels[collection]}</a>
    </div>
  </div>
</BaseLayout>

<style>
  .post-dek {
    max-width: 68ch;
    margin: -8px 0 28px;
    color: var(--text-2);
    font-size: clamp(17px, 2vw, 19px);
    line-height: 1.75;
  }

  .post-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, auto));
    justify-content: start;
    width: fit-content;
    max-width: 100%;
  }

  .post-meta div {
    min-width: 130px;
    padding: 12px 16px 12px 0;
    background: transparent;
  }

  .post-meta div + div {
    padding-left: 16px;
  }

  .post-meta-topic {
    min-width: min(340px, 100%);
  }

  .post-meta dt {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .post-meta dt svg {
    color: var(--accent);
    opacity: 0.85;
  }

  .post-meta dd {
    color: var(--text-2);
    font-size: 13px;
  }

  .post-meta time,
  .post-meta dd:not(.post-meta-tags) {
    font-family: var(--font-mono);
  }

  .post-meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .post-footer {
    padding: 24px 0 40px;
    margin-top: 28px;
  }

  @media (max-width: 680px) {
    .post-meta {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .post-meta div {
      padding: 12px 0;
    }

    .post-meta div + div {
      padding-left: 0;
    }
  }
</style>
