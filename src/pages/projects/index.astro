---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const icons: Record<string, string> = {
  github: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  gitlab: `<path d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.06 3.26a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.69-6.88a.71.71 0 0 0 .31-.83Z"/>`,
  npm:    `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M12 7v14M8 7v14M16 7v14"/>`,
  web:    `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  terminal: `<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>`,
};
---

<BaseLayout title="Projects" description="Tools, scripts, and side projects I've built and open-sourced.">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header-title">Projects</h1>
      <p class="page-header-desc">Tools, scripts, and side projects I've built and open-sourced.</p>
      <div class="page-header-meta" aria-label="Projects index metadata">
        <span><strong>{projects.length}</strong> projects</span>
        <span>source, demos, and writeups</span>
      </div>
    </header>

    {projects.length > 0 ? (
    <div class="project-grid">
      {projects.map(project => {
        const href = project.data.url ?? project.data.github ?? `/projects/${project.slug}`;
        const external = href.startsWith('http');
        const iconPaths = icons[project.data.icon ?? 'github'];
        const dateStr = project.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const targetLabel = project.data.github ? 'source' : project.data.url ? 'demo' : 'writeup';

        return (
          <a
            href={href}
            class="projects-list-card"
            data-status={project.data.status}
            {...(external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <div class="projects-list-icon" aria-hidden="true">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths} />
            </div>

            <div class="projects-list-body">
              <div class="projects-list-top">
                <h2 class="projects-list-title">{project.data.title}</h2>
                <span class={`status-badge status-${project.data.status}`}>
                  {project.data.status}
                </span>
              </div>
              <div class="projects-list-meta">
                <time datetime={project.data.date.toISOString()}>{dateStr}</time>
                {external && <span>external ↗</span>}
              </div>
              <p class="projects-list-desc">{project.data.description}</p>
              {project.data.tags.length > 0 && (
                <div class="projects-list-tags" aria-label="Stack and topics">
                  {project.data.tags.slice(0, 5).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              )}
              <div class="projects-list-footer" aria-hidden="true">
                <span>{targetLabel}</span>
                <span>open ↗</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
    ) : (
      <p class="empty-state">No projects published yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    padding: 8px 0 64px;
  }

  .projects-list-card {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 18px;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .projects-list-card:hover,
  .projects-list-card:focus-visible {
    border-bottom-color: var(--border-2);
  }

  .projects-list-card:hover .projects-list-title,
  .projects-list-card:focus-visible .projects-list-title {
    color: var(--text);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
  }

  .projects-list-icon {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    color: var(--text-3);
    transition: color var(--transition);
  }

  .projects-list-card:hover .projects-list-icon,
  .projects-list-card:focus-visible .projects-list-icon {
    color: var(--text-2);
  }

  .projects-list-body {
    min-width: 0;
  }

  .projects-list-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 6px;
  }

  .projects-list-title {
    min-width: 0;
    font-family: var(--font-serif);
    font-size: clamp(21px, 3vw, 25px);
    font-weight: 320;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.18;
    overflow-wrap: anywhere;
    transition: color var(--transition), text-decoration-color var(--transition);
  }

  .projects-list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    margin-bottom: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .projects-list-desc {
    max-width: 68ch;
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.72;
    margin-bottom: 12px;
  }

  .projects-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }

  .projects-list-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    transition: color var(--transition);
  }

  .projects-list-card:hover .projects-list-footer,
  .projects-list-card:focus-visible .projects-list-footer {
    color: var(--text-2);
  }

  @media (max-width: 560px) {
    .projects-list-card {
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 14px;
      padding: 18px 0;
    }

    .projects-list-icon {
      width: 34px;
      height: 34px;
    }

    .projects-list-top {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
