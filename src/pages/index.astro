---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allBlog     = await getCollection('blog',     ({ data }) => !data.draft);
const allResearch = await getCollection('research', ({ data }) => !data.draft);
const allNotes    = await getCollection('notes',    ({ data }) => !data.draft);

const allPosts = [
  ...allBlog    .map(p => ({ ...p, collection: 'blog'     as const })),
  ...allResearch.map(p => ({ ...p, collection: 'research' as const })),
  ...allNotes   .map(p => ({ ...p, collection: 'notes'    as const })),
]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Danko Delimar">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="hero-eyebrow">dantae.dev</p>
          <h1 class="hero-name">Dantae</h1>
          <p class="hero-tagline">
            Security research, tooling, and field notes. I write about vulnerabilities,
            reconnaissance workflows, CTFs, and the small utilities that make investigations easier.
          </p>
          <nav class="hero-actions" aria-label="Social links">
            <a href="https://github.com/D4ntae" class="hero-action hero-action-primary" target="_blank" rel="noopener" aria-label="GitHub">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
            </a>
            <a href="https://twitter.com/dankodelimar" class="hero-action" target="_blank" rel="noopener" aria-label="X / Twitter">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="mailto:danko.delimar@gmail.com" class="hero-action" aria-label="Email">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </a>
            <a href="/rss.xml" class="hero-action" aria-label="RSS feed">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 11a9 9 0 0 1 9 9"/>
                <path d="M4 4a16 16 0 0 1 16 16"/>
                <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          </nav>
        </div>

        <aside class="focus-panel" aria-label="Current focus">
          <p class="focus-kicker">current focus</p>
          <ul class="focus-list" role="list">
            <li>
              <span class="focus-index">01</span>
              <span>web vulnerability research</span>
            </li>
            <li>
              <span class="focus-index">02</span>
              <span>recon automation &amp; tooling</span>
            </li>
            <li>
              <span class="focus-index">03</span>
              <span>practical security notes</span>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="home-recent" aria-labelledby="recent-heading">
    <div class="container">
      <div class="home-section-header">
        <h2 id="recent-heading" class="home-section-title">Research archive</h2>
      </div>
      <div class="post-list">
        {allPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            href={`/${post.collection}/${post.slug}`}
            collection={post.collection}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: clamp(32px, 7vw, 72px);
    align-items: end;
  }

  .hero-copy {
    min-width: 0;
  }

  .focus-panel {
    padding-top: 4px;
    margin-bottom: 8px;
  }

  .focus-kicker,
  .home-section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--text-3);
  }

  .focus-kicker {
    margin-bottom: 14px;
  }

  .focus-list {
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .focus-list li {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 12px;
    align-items: baseline;
    color: var(--text-2);
    font-size: 14px;
    line-height: 1.5;
  }

  .focus-index {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 11px;
  }

  .home-recent {
    padding-bottom: 24px;
  }

  .home-section-header {
    padding: 24px 0 22px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .home-section-title {
    font-family: var(--font-serif);
    font-size: clamp(25px, 4vw, 34px);
    font-weight: 350;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text);
    margin-top: 8px;
  }

  @media (max-width: 760px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .focus-panel {
      margin-bottom: 0;
    }
  }
</style>
