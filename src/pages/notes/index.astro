---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0) || a.data.title.localeCompare(b.data.title));

// Group by folder (first segment of slug path)
const byFolder: Record<string, typeof allNotes> = {};
for (const note of allNotes) {
  const parts = note.slug.split('/');
  const folder = parts.length > 1 ? parts[0] : '_root';
  if (!byFolder[folder]) byFolder[folder] = [];
  byFolder[folder].push(note);
}

// Separate root-level notes and categorized notes
const { _root: rootNotes = [], ...folders } = byFolder;
const sortedFolders = Object.entries(folders).sort(([a], [b]) => a.localeCompare(b));

// For each note, find its children (notes with parent = this note's slug)
function getChildren(slug: string) {
  return allNotes.filter(n => n.data.parent === slug);
}
function isTopLevel(note: (typeof allNotes)[0]) {
  return !note.data.parent;
}
---

<BaseLayout title="Notes" description="Security reference notes and cheatsheets, organized by topic.">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header-title">Notes</h1>
      <p class="page-header-desc">
        Reference notes organized like an Obsidian vault. Cheatsheets, commands, and small explanations grouped by topic.
      </p>
      <div class="page-header-meta" aria-label="Notes index metadata">
        <span><strong>{allNotes.length}</strong> notes</span>
        <span><strong>{sortedFolders.length + (rootNotes.length > 0 ? 1 : 0)}</strong> sections</span>
      </div>
    </header>

    {allNotes.length > 0 ? (
    <div class="wiki-index">
      {sortedFolders.map(([folder, notes]) => {
        const topLevel = notes.filter(isTopLevel);
        return (
          <section class="wiki-category">
            <h2 class="wiki-category-header">
              <span>{folder.replace(/-/g, ' ')}</span>
            </h2>
            <ul class="wiki-note-list">
              {topLevel.map(note => {
                const children = getChildren(note.slug);
                return (
                  <li class="wiki-note-item">
                    <a href={`/notes/${note.slug}`} class="wiki-note-link">
                      <span class="wiki-note-title">{note.data.title}</span>
                      <span class="wiki-note-desc">{note.data.description}</span>
                    </a>
                    {children.length > 0 && (
                      <ul class="wiki-children">
                        {children.map(child => (
                          <li class="wiki-child-item">
                            <a href={`/notes/${child.slug}`} class="wiki-child-link">
                              <span>{child.data.title}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}

      {rootNotes.filter(isTopLevel).length > 0 && (
        <section class="wiki-category">
          <h2 class="wiki-category-header">
            <span>general</span>
          </h2>
          <ul class="wiki-note-list">
            {rootNotes.filter(isTopLevel).map(note => {
              const children = getChildren(note.slug);
              return (
                <li class="wiki-note-item">
                  <a href={`/notes/${note.slug}`} class="wiki-note-link">
                    <span class="wiki-note-title">{note.data.title}</span>
                    <span class="wiki-note-desc">{note.data.description}</span>
                  </a>
                  {children.length > 0 && (
                    <ul class="wiki-children">
                      {children.map(child => (
                        <li class="wiki-child-item">
                          <a href={`/notes/${child.slug}`} class="wiki-child-link">
                            <span>{child.data.title}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}
    </div>
    ) : (
      <p class="empty-state">No notes published yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .wiki-index {
    display: grid;
    gap: 22px;
    max-width: 680px;
    padding-bottom: 64px;
  }

  .wiki-category {
    min-width: 0;
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr);
    gap: 22px;
    padding: 0;
  }

  .wiki-category-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-3);
    padding-top: 1px;
  }

  .wiki-category-header span:first-child::before {
    content: '/';
    color: var(--accent);
    margin-right: 2px;
  }

  .wiki-note-list {
    list-style: none;
    display: grid;
    gap: 6px;
  }

  .wiki-note-link {
    display: grid;
    gap: 2px;
    padding: 0;
    color: var(--text-2);
    transition: color var(--transition);
  }

  .wiki-note-link:hover,
  .wiki-note-link:focus-visible {
    color: var(--accent-strong);
  }

  .wiki-note-title {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.35;
    color: var(--text);
  }

  .wiki-note-desc {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.45;
    max-width: 58ch;
    padding-left: 0;
  }

  .wiki-children {
    list-style: none;
    margin: 0 0 4px 18px;
    padding-left: 12px;
  }

  .wiki-child-link {
    display: block;
    padding: 2px 0;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.4;
    transition: color var(--transition);
  }

  .wiki-child-link:hover,
  .wiki-child-link:focus-visible {
    color: var(--text);
  }

  @media (max-width: 680px) {
    .wiki-category {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .wiki-category-header {
      justify-content: flex-start;
    }
  }
</style>
