---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Research" description="Vulnerability analysis, CTF writeups, and original security findings.">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header-title">Research</h1>
      <p class="page-header-desc">Vulnerability analysis, CTF writeups, and original security findings.</p>
      <div class="page-header-meta" aria-label="Research index metadata">
        <span><strong>{posts.length}</strong> reports</span>
        <span>ordered by publication date</span>
      </div>
    </header>

    {posts.length > 0 ? (
      <div class="post-list">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            href={`/research/${post.slug}`}
            collection="research"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No research reports published yet.</p>
    )}
  </div>
</BaseLayout>
