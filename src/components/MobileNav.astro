---
const pathname = Astro.props.pathname as string;

const links = [
  { href: '/blog',     label: 'blog'     },
  { href: '/research', label: 'research' },
  { href: '/notes',    label: 'notes'    },
  { href: '/projects', label: 'projects' },
];

const year = new Date().getFullYear();
---

<button id="mobile-nav-toggle" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
    <line x1="4" y1="6"  x2="20" y2="6"/>
    <line x1="4" y1="12" x2="20" y2="12"/>
    <line x1="4" y1="18" x2="20" y2="18"/>
  </svg>
</button>

<div id="mobile-drawer" class="drawer" role="dialog" aria-modal="true" aria-label="Navigation" hidden>
  <div class="drawer-backdrop"></div>
  <div class="drawer-panel">
    <div class="drawer-top">
      <a href="/" class="drawer-name">Dantae</a>
      <p class="drawer-tagline">security researcher &amp; builder</p>
    </div>

    <nav class="drawer-nav" aria-label="Main">
      <ul role="list">
        {links.map(link => {
          const active = pathname.startsWith(link.href);
          return (
            <li>
              <a href={link.href} class:list={['drawer-link', { 'drawer-link--active': active }]}>
                <span class="drawer-link-dot"></span>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="drawer-footer">
      <div class="drawer-links">
        <a href="https://github.com/D4ntae" class="drawer-ext-link" target="_blank" rel="noopener">github ↗</a>
        <a href="mailto:danko.delimar@gmail.com" class="drawer-ext-link">email</a>
        <a href="/rss.xml" class="drawer-ext-link">rss</a>
      </div>
      <p class="drawer-copy">© {year} Danko Delimar</p>
    </div>
  </div>
</div>

<script>
  const toggle  = document.getElementById('mobile-nav-toggle')!;
  const drawer  = document.getElementById('mobile-drawer')!;
  const backdrop = drawer.querySelector('.drawer-backdrop')!;

  function open() {
    drawer.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    drawer.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', open);
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>

<style>
  .nav-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text-2);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-toggle:hover { color: var(--text); }

  .drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
  }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 9, 13, 0.72);
  }

  :global([data-theme='light']) .drawer-backdrop {
    background: rgba(28, 32, 38, 0.28);
  }

  .drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 260px;
    background: var(--bg);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 36px 28px 28px;
  }

  .drawer-top { margin-bottom: 40px; }

  .drawer-name {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.035em;
    margin-bottom: 8px;
    transition: color var(--transition);
  }

  .drawer-name:hover { color: var(--accent-strong); }

  .drawer-tagline {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .drawer-nav { flex: 1; }

  .drawer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .drawer-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-2);
    margin-left: -10px;
  }

  .drawer-link:hover { color: var(--text); background: var(--surface); }
  .drawer-link--active { color: var(--accent); }

  .drawer-link-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: currentColor;
    opacity: 0;
    flex-shrink: 0;
  }

  .drawer-link--active .drawer-link-dot { opacity: 1; }

  .drawer-footer {
    border-top: 1px solid var(--border);
    padding-top: 20px;
    margin-top: 20px;
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }

  .drawer-ext-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.06em;
  }

  .drawer-ext-link:hover { color: var(--accent); }

  .drawer-copy {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }
</style>
