---
const pathname = Astro.url.pathname;

const links = [
  { href: '/blog',     label: 'blog'     },
  { href: '/research', label: 'research' },
  { href: '/notes',    label: 'notes'    },
  { href: '/projects', label: 'projects' },
];

const year = new Date().getFullYear();
---

<aside class="sidebar">
  <div class="sidebar-top">
    <a href="/" class="sidebar-logo" aria-label="Home">
      DD<span class="sidebar-logo-dot">.</span>
    </a>
    <p class="sidebar-name">Danko Delimar <span class="sidebar-nick">/ dantae</span></p>
    <p class="sidebar-tagline">security researcher &amp; builder</p>
  </div>

  <nav class="sidebar-nav" aria-label="Main">
    <ul role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['sidebar-link', { 'sidebar-link--active': pathname.startsWith(link.href) }]}
          >
            <span class="sidebar-link-indicator"></span>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-socials">
      <a href="https://github.com/D4ntae" class="sidebar-icon-link" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
      </a>
      <a href="https://twitter.com/dankodelimar" class="sidebar-icon-link" target="_blank" rel="noopener" aria-label="Twitter / X">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="mailto:danko.delimar@gmail.com" class="sidebar-icon-link" aria-label="Email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
    <p class="sidebar-copy">© {year} Danko Delimar</p>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 36px 28px 28px;
  }

  .sidebar-top {
    margin-bottom: 40px;
  }

  .sidebar-logo {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.04em;
    margin-bottom: 10px;
    transition: opacity 120ms;
  }

  .sidebar-logo:hover { opacity: 0.8; }

  .sidebar-logo-dot { color: var(--amber); }

  .sidebar-name {
    font-size: 11px;
    color: var(--text-2);
    letter-spacing: 0.03em;
    margin-bottom: 4px;
  }

  .sidebar-nick {
    color: var(--amber);
    opacity: 0.7;
  }

  .sidebar-tagline {
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.04em;
    line-height: 1.6;
  }

  .sidebar-nav {
    flex: 1;
  }

  .sidebar-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-2);
    border-radius: 0;
    transition: all 130ms;
    position: relative;
    margin-left: -10px;
    width: calc(100% + 10px);
  }

  .sidebar-link:hover {
    color: var(--text);
    background: var(--surface);
  }

  .sidebar-link--active {
    color: var(--amber);
  }

  .sidebar-link--active:hover { background: var(--amber-dim); }

  .sidebar-link-indicator {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: currentColor;
    opacity: 0;
    transition: opacity 130ms;
    flex-shrink: 0;
  }

  .sidebar-link--active .sidebar-link-indicator { opacity: 1; }
  .sidebar-link:hover .sidebar-link-indicator { opacity: 0.4; }
  .sidebar-link--active:hover .sidebar-link-indicator { opacity: 1; }

  .sidebar-footer {
    padding-top: 20px;
    margin-top: 20px;
  }

  .sidebar-socials {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }

  .sidebar-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    color: var(--text-3);
    transition: color var(--transition), background var(--transition);
  }

  .sidebar-icon-link:hover {
    color: var(--amber);
    background: var(--amber-dim);
  }

  .sidebar-copy {
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }
</style>
