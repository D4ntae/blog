---
const pathname = Astro.url.pathname;

const links = [
  { href: '/blog',     label: 'blog'     },
  { href: '/research', label: 'research' },
  { href: '/notes',    label: 'notes'    },
  { href: '/projects', label: 'projects' },
];
---

<nav class="nav">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Home">
        DD<span class="nav-logo-dot">.</span>
      </a>
      <ul class="nav-links" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: pathname.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>
